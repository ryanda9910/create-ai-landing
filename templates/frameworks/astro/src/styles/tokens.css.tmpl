@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    --color-bg:           {{PRIMARY_COLOR}};
    --color-surface:      color-mix(in srgb, {{PRIMARY_COLOR}} 85%, white);
    --color-border:       color-mix(in srgb, {{PRIMARY_COLOR}} 70%, white);

    --color-primary:      #FFFFFF;
    --color-text:         rgba(255, 255, 255, 0.85);
    --color-text-muted:   rgba(255, 255, 255, 0.45);

    --color-accent:       {{ACCENT_COLOR}};
    --color-accent-2:     color-mix(in srgb, {{ACCENT_COLOR}} 60%, purple);

    --color-success:      #22C55E;
    --color-danger:       #EF4444;
  }

  html {
    background-color: var(--color-bg);
    color: var(--color-text);
  }
}

@layer components {
  .container-page {
    @apply max-w-7xl mx-auto px-6 md:px-12;
  }

  .label-uppercase {
    @apply text-xs font-mono uppercase tracking-[0.15em] text-text-muted;
  }

  .btn-primary {
    @apply inline-flex items-center gap-2 px-6 py-3 bg-accent text-bg font-medium text-sm uppercase tracking-widest transition-all duration-300 hover:opacity-90;
  }

  .btn-secondary {
    @apply inline-flex items-center gap-2 px-6 py-3 border border-border text-primary font-medium text-sm uppercase tracking-widest transition-all duration-300 hover:border-accent hover:text-accent;
  }
}
