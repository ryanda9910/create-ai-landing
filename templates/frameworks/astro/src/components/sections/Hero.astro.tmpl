---
import { SITE } from '../../lib/site';
---

<section class="relative min-h-dvh flex items-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <video
      autoplay muted loop playsinline
      poster="/images/hero-poster.jpg"
      class="w-full h-full object-cover opacity-30 motion-reduce:hidden"
    >
      <source src="/videos/hero-loop.webm" type="video/webm" />
      <source src="/videos/hero-loop.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-bg/20 via-transparent to-bg"></div>
  </div>

  <div class="relative z-10 container-page pt-32 pb-24">
    <p class="label-uppercase mb-8">{SITE.name} — {SITE.city}</p>

    <h1 class="font-display text-display text-primary max-w-3xl mb-8 leading-none">
      {{TAGLINE}}
    </h1>

    <p class="text-body-lg text-text-muted max-w-xl mb-12">
      <!-- Replace with specific description — name formats, specs, location -->
      [Your specific description here. Avoid vague adjectives.]
    </p>

    <div class="flex flex-wrap gap-4">
      <a href="#contact" class="btn-primary">Start a project</a>
      <a href="#works" class="btn-secondary">See the work</a>
    </div>
  </div>
</section>
