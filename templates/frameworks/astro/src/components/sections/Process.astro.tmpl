---
import { PROCESS_STEPS } from '../../lib/process';
---

<section id="process" class="py-24 md:py-32 bg-surface">
  <div class="container-page">
    <div class="mb-16 md:mb-24">
      <p class="label-uppercase mb-4">Process</p>
      <h2 class="font-display text-h1 text-primary max-w-xl">Transparent from day one.</h2>
    </div>

    <div class="flex flex-col gap-0">
      {PROCESS_STEPS.map((step, i) => (
        <div class="border-t border-border py-12 md:py-16 grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-8 md:gap-16 items-start">
          <div class={i % 2 === 0 ? 'md:col-start-1' : 'md:col-start-3 md:row-start-1'}>
            {i % 2 !== 0 ? (
              <div>
                <p class="text-body text-text-muted leading-relaxed">{step.description}</p>
                <p class="font-mono text-mono text-accent mt-4">→ {step.detail}</p>
              </div>
            ) : (
              <div>
                <span class="font-mono text-mono text-text-muted">{step.number}</span>
                <h3 class="font-display text-h2 text-primary mt-2">{step.title}</h3>
                <p class="label-uppercase text-accent mt-4">{step.duration}</p>
              </div>
            )}
          </div>

          <div class="hidden md:flex flex-col items-center pt-2">
            <div class="w-px h-full min-h-[60px] bg-border"></div>
          </div>

          <div class={i % 2 === 0 ? 'md:col-start-3' : 'md:col-start-1 md:row-start-1'}>
            {i % 2 === 0 ? (
              <div>
                <p class="text-body text-text-muted leading-relaxed">{step.description}</p>
                <p class="font-mono text-mono text-accent mt-4">→ {step.detail}</p>
              </div>
            ) : (
              <div>
                <span class="font-mono text-mono text-text-muted">{step.number}</span>
                <h3 class="font-display text-h2 text-primary mt-2">{step.title}</h3>
                <p class="label-uppercase text-accent mt-4">{step.duration}</p>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
